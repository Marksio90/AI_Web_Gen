---
export interface Service {
  name: string;
  description: string;
  price?: string;
  icon?: string;
}

export interface Props {
  services: Service[];
  title?: string;
  variant?: "grid" | "list" | "cards";
}

const {
  services,
  title = "Nasze Usługi",
  variant = "grid",
} = Astro.props;

const defaultIcons: Record<number, string> = {
  0: "✂️", 1: "💆", 2: "💅", 3: "🔧", 4: "⭐", 5: "🏆", 6: "💎", 7: "🌟",
};
---

<section id="uslugi" class="py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-4" style="color: var(--color-primary);">
      {title}
    </h2>
    <div class="w-16 h-1 mx-auto mb-12 rounded" style="background-color: var(--color-accent);" />

    {variant === "grid" && (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((service, i) => (
          <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow border border-gray-100">
            <div class="text-3xl mb-4">{service.icon || defaultIcons[i % 8]}</div>
            <h3 class="font-heading text-xl font-semibold mb-3" style="color: var(--color-primary);">
              {service.name}
            </h3>
            <p class="text-gray-600 leading-relaxed">{service.description}</p>
            {service.price && (
              <p class="mt-4 font-semibold" style="color: var(--color-accent);">
                od {service.price}
              </p>
            )}
          </div>
        ))}
      </div>
    )}

    {variant === "list" && (
      <div class="space-y-6 max-w-3xl mx-auto">
        {services.map((service) => (
          <div class="flex gap-6 items-start bg-white rounded-xl p-6 shadow-sm">
            <div
              class="w-12 h-12 rounded-full flex items-center justify-center text-white flex-shrink-0 font-bold"
              style="background-color: var(--color-primary);"
            >
              ✓
            </div>
            <div>
              <h3 class="font-heading text-xl font-semibold mb-2" style="color: var(--color-primary);">
                {service.name}
              </h3>
              <p class="text-gray-600">{service.description}</p>
              {service.price && (
                <p class="mt-2 font-semibold text-sm" style="color: var(--color-accent);">
                  {service.price}
                </p>
              )}
            </div>
          </div>
        ))}
      </div>
    )}

    {variant === "cards" && (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((service, i) => (
          <div
            class="rounded-xl p-6 text-white text-center"
            style="background-color: var(--color-primary);"
          >
            <div class="text-4xl mb-4">{service.icon || defaultIcons[i % 8]}</div>
            <h3 class="font-heading text-lg font-semibold mb-3">{service.name}</h3>
            <p class="text-sm opacity-85 leading-relaxed">{service.description}</p>
            {service.price && (
              <p class="mt-4 font-bold text-lg" style="color: var(--color-accent);">
                {service.price}
              </p>
            )}
          </div>
        ))}
      </div>
    )}
  </div>
</section>
