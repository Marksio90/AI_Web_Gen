################################################################################
# AI Web Generator — Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to git!
################################################################################

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=aiwebgen
POSTGRES_PASSWORD=change-me-securepass
POSTGRES_DB=ai_web_gen

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redispass

# ─── AI APIs ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...           # Free tier: get at console.groq.com

# ─── Google APIs ─────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...    # Enable: Places API (New), PageSpeed Insights
PAGESPEED_API_KEY=AIza...      # Same key or separate; 25K free queries/day

# ─── Authentication (next-auth v5) ───────────────────────────────────────────
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GOOGLE_ID=                # Optional: Google OAuth (leave empty to disable)
AUTH_GOOGLE_SECRET=

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STARTER=price_...   # 29 PLN/month recurring
STRIPE_PRICE_BUSINESS=price_...  # 79 PLN/month recurring
STRIPE_PRICE_PRO=price_...       # 129 PLN/month recurring

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
OUTREACH_FROM_EMAIL=demo@yourplatform.pl
OUTREACH_FROM_NAME=AI Web Generator

# ─── Cloudflare R2 (demo site hosting) ───────────────────────────────────────
CF_ACCOUNT_ID=
CF_R2_ACCESS_KEY=
CF_R2_SECRET_KEY=
CF_R2_BUCKET=demo-sites

# ─── Platform ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost         # Change to https://yourplatform.pl in prod
DEMO_BASE_DOMAIN=demo.yourplatform.pl

# ─── Security ────────────────────────────────────────────────────────────────
AGENT_API_SECRET=change-me-secret           # Internal service auth

# ─── Celery Flower UI ────────────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=change-me-flowerpass
FLOWER_BASIC_AUTH_TRAEFIK=admin:$$apr1$$...  # htpasswd format (for prod Traefik)

# ─── Monitoring ─────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-grafanapass

# ─── Production only ─────────────────────────────────────────────────────────
DOMAIN=yourplatform.pl
ACME_EMAIL=admin@yourplatform.pl
