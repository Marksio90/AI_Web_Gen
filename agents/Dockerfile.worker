# ─────────────────────────────────────────────────────────────────────────────
# Celery Worker — reuses agents image layers, same build context (repo root)
# ─────────────────────────────────────────────────────────────────────────────
FROM python:3.12-slim AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
RUN pip install --no-cache-dir uv
COPY agents/requirements.txt .
RUN uv pip install --system --no-cache -r requirements.txt

# ─────────────────────────────────────────────────────────────────────────────
FROM python:3.12-slim AS runner

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd -g 1001 celery && useradd -u 1001 -g celery -m -s /bin/bash celery

WORKDIR /app

COPY --from=builder /usr/local/lib/python3.12/site-packages /usr/local/lib/python3.12/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy BOTH agents + crawler (tasks.py imports crawler/)
COPY --chown=celery:celery agents/ /app/
COPY --chown=celery:celery crawler/ /app/crawler/

USER celery

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONPATH=/app
ENV C_FORCE_ROOT=false

HEALTHCHECK --interval=60s --timeout=30s --start-period=60s --retries=3 \
  CMD celery -A tasks inspect ping -d "celery@$$HOSTNAME" --timeout 10 || exit 1

CMD ["celery", "-A", "tasks", "worker", \
     "--loglevel=info", \
     "--concurrency=4", \
     "--max-tasks-per-child=100", \
     "-Q", "pipeline,crawler,email,default", \
     "--hostname=worker@%h"]
