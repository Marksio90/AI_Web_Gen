# OpenAI
OPENAI_API_KEY=sk-...

# Groq (free tier fallback)
GROQ_API_KEY=gsk_...

# Database (for local non-Docker development only; Docker uses values from root .env)
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/ai_web_gen

# Redis (for local non-Docker development only; Docker uses values from root .env)
REDIS_URL=redis://localhost:6379/0

# Google Maps
GOOGLE_MAPS_API_KEY=AIza...

# PageSpeed Insights
PAGESPEED_API_KEY=AIza...

# Cloudflare R2 (demo site hosting)
CF_ACCOUNT_ID=...
CF_R2_ACCESS_KEY=...
CF_R2_SECRET_KEY=...
CF_R2_BUCKET=demo-sites

# Platform domain
DEMO_BASE_DOMAIN=demo.yourplatform.pl

# Logging
LOG_LEVEL=INFO
